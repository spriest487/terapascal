implementation
uses System;

type BigBox = class
    a: box of Integer;
    b: box of Integer;
end;

initialization
    var boxes := BigBox(a: [1]; b: [2]);
    
    var a := boxes.a;
    var aVal := a^;
    var bVal := boxes.b^;

    WriteLn('box contents:');
    WriteLn(IntToStr(aVal));
    WriteLn(IntToStr(bVal));
end
