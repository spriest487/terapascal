implementation
uses System;

type MyBox = class
    val1: Integer;
    val2: Boolean;
end;

type BoxBox = class
    myBox: MyBox;
end;

function DoNothing(bb: BoxBox);
begin
end;

initialization
    var box1 := MyBox(val1: 1; val2: true);
    
    var boxbox := BoxBox(myBox: box1);
    DoNothing(boxbox);
end
