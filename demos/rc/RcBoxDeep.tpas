program RcBoxDeep;

type
    MyObject = class
    end;

    MyArr = array[3] of MyObject;
    
    MyRecord = record
        obj1: MyObject;
        obj2: MyArr;
    end;

begin
    var objBox: Object := [MyRecord(
        obj1: MyObject();
        obj2: [
            MyObject(),
            MyObject(),
            MyObject(),
        ];
    )] as box of MyRecord;
end.
