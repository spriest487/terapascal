implementation
uses System;

type 
    MyObject = class
        name: String;
    end;

function PrintNth(xs: array of MyObject; n: Integer);
begin
    var x := xs[n];
    WriteLn(x.name);
end;

initialization
    var arr: array of MyObject := [
        (name: '1'),
        (name: '2'),
        (name: '3'),
    ];
    PrintNth(arr, 0);
    
    var arr2 := arr;
    PrintNth(arr2, 2);
end
