implementation
uses System;

type IntBox = class
    val: Integer;
end;

function Id(intBox: IntBox): IntBox;
begin
    intBox
end;

function New(): IntBox;
begin
    IntBox(val:456)
end;

initialization
    New();
    
    var intBox := IntBox(val: 1);
    Id(intBox);
    
    var intBox2 := IntBox(val: 1);
    intBox2 := New();
end
