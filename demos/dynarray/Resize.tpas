implementation
uses System;

initialization
    var x: array of Integer := [];
    SetLength(x, 0, 0);

    WriteLn(x.Length.ToString);
    SetLength(x, 2, 0);
    WriteLn(x.Length.ToString);

    var boxes: array of box of Integer := [[1], [2]];
    boxes.SetLength(1, [0]);
    
    for var b in boxes do 
    begin
        WriteLn('array now contains: ' + b^);
    end;
end
