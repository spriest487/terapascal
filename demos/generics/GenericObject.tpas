implementation
uses System;

type TestBox[Val] = class
    val: Val;
end;

function UnwrapTestBox[T](testBox: TestBox[T]): T;
begin
    testBox.val
end;

initialization
    // first ctor needs explicit types, subsequently can be inferred from type of var 
    var testBox := TestBox with [array[1] of Integer](val: [5]);
    
    testBox := TestBox[array[1] of Integer](val: [3]);
    
    testBox := TestBox(val: [1]);

    var val := UnwrapTestBox(testBox);
    WriteLn(IntToStr(val[0]));
end
